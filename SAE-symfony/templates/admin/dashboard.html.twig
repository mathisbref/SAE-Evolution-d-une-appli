{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="dashboard-container">

    <h1>Dashboard</h1>

    <!-- 📊 Bulles des statistiques -->
    <div class="stats-bubble-container">
        <div class="stats-bubble">
            <span>Taux d'occupation</span>
            <strong>{{ tauxOccupation|number_format(2) }}%</strong>
        </div>
        <div class="stats-bubble">
            <span>Taux d'absentéisme</span>
            <strong>{{ tauxAbsenteisme|number_format(2) }}%</strong>
        </div>
    </div>

    <!-- 📋 Liste des séances populaires -->
    <h3>Séances les plus populaires</h3>
    <div class="seances-populaires">
        {% for seance in seancesPopulaires %}
            <div class="seance-card">
                <div class="seance-info">
                    <span class="seance-date">📅 {{ seance.date_heure|date("d/m/Y") }}</span> <br>
                    <span class="seance-coach">👨‍🏫 Coach : {{ seance.Coach }}</span>
                </div>
                <div class="seance-participants">
                    👥 {{ seance.nb_participants }} participants
                </div>
            </div>
        {% endfor %}
    </div>

</div>

<style>
    /* Conteneur principal */
    .dashboard-container {
        max-width: 1200px;
        margin: auto;
        padding: 20px;
    }

    /* Bulles des statistiques */
    .stats-bubble-container {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-bottom: 30px;
    }

    .stats-bubble {
        width: 150px;
        height: 150px;
        background: #4CAF50;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        font-size: 18px;
        font-weight: bold;
        text-align: center;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
    }

    /* Liste des séances populaires */
    .seances-populaires {
        margin-top: 20px;
    }

    .seance-card {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
    }

    .seance-info {
        font-size: 16px;
    }

    .seance-date {
        font-weight: bold;
        color: #333;
    }

    .seance-coach {
        font-style: italic;
        color: #555;
    }

    .seance-participants {
        font-weight: bold;
        color: #4CAF50;
    }
</style>

{% endblock %}

